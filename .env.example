# ─────────────────────────────────────────────────────────────────
# Google Sheets → HeyGen Automation  •  Configuration Template
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Google Sheets ─────────────────────────────────────────────────
# Paste your entire Google Service Account JSON here (as a single line)
# Download from: https://console.cloud.google.com → Service Account → Keys → Add Key → JSON
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Sheet ID — the long string in your sheet's URL:
# https://docs.google.com/spreadsheets/d/  THIS_PART  /edit
GOOGLE_SHEET_ID=

# Tab name at the bottom of your Google Sheet
GOOGLE_SHEET_NAME=Sheet1

# ── Polling ───────────────────────────────────────────────────────
# How often (seconds) to check for new "Approved" rows
POLL_INTERVAL=30

# ── HeyGen ────────────────────────────────────────────────────────
# https://app.heygen.com/settings/api-key
HEYGEN_API_KEY=

# Avatar ID — find at https://app.heygen.com/avatars
HEYGEN_AVATAR_ID=

# How often (seconds) to poll HeyGen while video is rendering
HEYGEN_POLL_SECS=15

# Video output resolution: 720p, 1080p, or 4k
VIDEO_RESOLUTION=1080p

# Video aspect ratio: 16:9 (desktop/horizontal) or 9:16 (mobile/vertical)
VIDEO_ASPECT_RATIO=16:9
